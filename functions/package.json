{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "rm -rf lib && tsc",
    "build:watch": "tsc --watch",
    "serve": "firebase use fire-base-project-id-01 && npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "dev": "npm run serve",
    "deploy": "GOOGLE_APPLICATION_CREDENTIALS=./gcp_credentials.json firebase deploy --only functions --non-interactive --debug",
    "logs": "firebase functions:log",
    "test": "echo \"No test specified\" && exit 0"
  },
  "engines": {
    "node": "24"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@genkit-ai/vertexai": "^1.3.0",
    "@google-cloud/secret-manager": "^6.0.1",
    "compression": "^1.8.0",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "firebase-admin": "^13.2.0",
    "firebase-functions": "^7.1.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "ramda": "^0.32.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.1.0",
    "firebase-tools": "^15.10.0",
    "typescript": "^6.0.2"
  },
  "private": true
}
