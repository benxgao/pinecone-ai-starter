{
  "name": "functions",
  "scripts": {
    "lint": "eslint .",
    "build": "rm -rf lib && tsc",
    "build:watch": "tsc --watch",
    "serve": "firebase use pinecone-ai-starter && npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "dev": "npm run serve",
    "deploy": "GOOGLE_APPLICATION_CREDENTIALS=./gcp_credentials.json firebase deploy --only functions --non-interactive --debug",
    "logs": "firebase functions:log",
    "test": "echo \"No test specified\" && exit 0"
  },
  "engines": {
    "node": "24"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/secret-manager": "^6.0.1",
    "compression": "^1.8.0",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "firebase-admin": "^13.2.0",
    "firebase-functions": "^7.1.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "ramda": "^0.32.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "eslint": "^9.39.4",
    "firebase-functions-test": "^3.1.0",
    "firebase-tools": "^15.12.0",
    "typescript": "^6",
    "typescript-eslint": "^8.58.0"
  },
  "private": true
}
