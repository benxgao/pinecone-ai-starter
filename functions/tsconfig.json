{
  "compilerOptions": {
    "module": "NodeNext",
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "rootDir": "./src",
    "outDir": "./lib",
    "sourceMap": true,
    "strict": true,
    "resolveJsonModule": true,
    "target": "ES2020",
    "lib": ["ES2020"]
  },
  "compileOnSave": true,
  "include": ["src/**/*"]
}
